    code_elements :
     type_code : 4
     p_codes :
      -
        code : |1+
         // on va chercher les titres de film pour instancier
         resultats	est une Structure
         	titre	est une chaîne
         	id		est un entier
         fin
         
         lstResultats est une Liste de resultats = film.SearchMovie(SAI_Film)
         
         si titre_film..Vide alors
         	pour tout resultat de lstResultats
         		titre_film.Ajoute(resultat.titre + tab + resultat.id)
         	fin
         sinon
         	ListeSupprimeTout(titre_film)
         	pour tout resultat de lstResultats
         		titre_film.Ajoute(resultat.titre + TAB + resultat.id)
         	fin
         FIN
         
        type : 18
      -
        type : 161
        enabled : false
