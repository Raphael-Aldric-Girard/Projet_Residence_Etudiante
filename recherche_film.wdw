         structure_	est une Structure
         	title			est une chaîne
         	original_title est une chaîne
         	poster_path		est une chaîne
         	release_date	est une Date
         	overview		est une chaîne
         fin
         
         results_ligne_selectionnee est une structure_
         
         results_ligne_selectionnee = film.SearchMovieByID(titre_film.id_)
         
         posterpath = "https://image.tmdb.org/t/p/w200" + results_ligne_selectionnee.poster_path
         LST_Infos_film.Ajoute(results_ligne_selectionnee.title)
         LST_Infos_film.Ajoute(results_ligne_selectionnee.original_title)
         LST_Infos_film.Ajoute(dateverschaine(results_ligne_selectionnee.release_date))
